# =============================================================================
# Aegis Panel — /opt/aegis/.env (rendered by Ansible roles/marzneshin)
# Mode 0600. Owned by aegis:aegis. DO NOT commit this file.
#
# This file is the input to deploy/install/install.sh --from-env. install.sh
# fills any blank values with random secrets and re-writes this file in
# place; subsequent runs read whatever install.sh left behind. That keeps
# Ansible idempotent (template drift only triggers a panel restart, not
# a credential rotation).
# =============================================================================

AEGIS_VERSION={{ aegis_version }}
AEGIS_DOMAIN={{ aegis_domain }}

# === Core security =========================================================
UVICORN_HOST=127.0.0.1
UVICORN_PORT={{ panel_port }}
UVICORN_UDS=
UVICORN_SSL_CERTFILE=
UVICORN_SSL_KEYFILE=

JWT_ACCESS_TOKEN_EXPIRE_MINUTES=45
JWT_SECRET_KEY={{ aegis_jwt_secret | default('', true) }}

# install.sh randomizes blanks below to 8 char URL-safe slugs on first run.
DASHBOARD_PATH=
XRAY_SUBSCRIPTION_PATH=

ADMIN_LOGIN_RATE_LIMIT=5/minute

# === Database ==============================================================
SQLALCHEMY_DATABASE_URL=

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=aegis
POSTGRES_USER=aegis
POSTGRES_PASSWORD=

# === Redis =================================================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# === Default admin =========================================================
SUDO_USERNAME={{ aegis_admin_username | default('', true) }}
SUDO_PASSWORD={{ aegis_admin_password | default('', true) }}

# === Xray policy (compass 五件套) ==========================================
XRAY_POLICY_CONN_IDLE=120
XRAY_POLICY_HANDSHAKE=2

# === Non-standard ports ====================================================
PANEL_PORT={{ panel_port }}
MARZNODE_GRPC_PORT={{ marznode_grpc_port }}

# === Cloudflare Tunnel =====================================================
CF_TUNNEL_ENABLED={{ 'true' if cf_tunnel_enabled | bool else 'false' }}
CF_ACCESS_REQUIRED_FOR_ADMIN=true
CF_TUNNEL_NAME=
CF_TUNNEL_UUID=
CF_ACCESS_ADMIN_EMAILS={{ cf_access_admin_emails | default('', true) }}

# === Reality 2026 SNI defaults =============================================
REALITY_SNI_REGION=auto
REALITY_SNI_DEFAULT_GLOBAL=www.microsoft.com
REALITY_SNI_DEFAULT_JP=www.lovelive-anime.jp
REALITY_SNI_DEFAULT_KR=static.naver.net
REALITY_SNI_DEFAULT_US=swdist.apple.com
REALITY_SNI_BLOCKLIST=www.google.com,speedtest.net

REALITY_UTLS_FINGERPRINT=chrome
REALITY_FLOW=xtls-rprx-vision

# === Fallback channel (compass 五件套, slot only in v0.2) ==================
FALLBACK_CHANNEL_ENABLED=false
FALLBACK_PORT_BACKUP=2053

# === Telegram bot (optional) ===============================================
TELEGRAM_API_TOKEN=
TELEGRAM_ADMIN_ID=

# === Subscription =========================================================
SUBSCRIPTION_URL_PREFIX=https://{{ aegis_domain }}
