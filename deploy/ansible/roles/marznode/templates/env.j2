# =============================================================================
# Aegis marznode — /opt/aegis-marznode/.env (rendered by Ansible roles/marznode)
# Mode 0600. Owned by aegis:aegis. DO NOT commit this file.
# =============================================================================

# === Identity =============================================================
MARZNODE_ID={{ marznode_id }}
MARZNODE_REGION={{ marznode_region | default('default', true) }}

# === Control plane endpoint ==============================================
# Single-CP topology — first host in the control_plane group is authoritative.
CONTROL_PLANE_HOST={{ hostvars[groups['control_plane'][0]]['ansible_host'] }}
CONTROL_PLANE_PORT={{ panel_port | default(8443) }}

# === gRPC server (data plane listens here) ===============================
MARZNODE_GRPC_HOST=0.0.0.0
MARZNODE_GRPC_PORT={{ marznode_grpc_port }}

# === mTLS material (rendered by tasks/main.yml from Ansible Vault) =======
MARZNODE_CERT_FILE={{ marznode_prefix }}/certs/marznode.pem
MARZNODE_KEY_FILE={{ marznode_prefix }}/certs/marznode.key
MARZNODE_CLIENT_CERT_FILE={{ marznode_prefix }}/certs/client.pem

# === Image tag pin ========================================================
MARZNODE_IMAGE_TAG={{ marznode_image_tag }}
