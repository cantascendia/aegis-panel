# =============================================================================
# Aegis Panel — production .env
# Generated by deploy/install/install.sh from deploy/install/templates/env.tmpl.
# DO NOT commit this file. Mode 600. Owned by aegis:aegis.
# =============================================================================
#
# This template is rendered by `deploy/install/lib/render.sh`. Tokens of
# the double-underscore form are substituted at install time. The mirror
# committed to the repo (deploy/.env.example) keeps the placeholders
# verbatim so users can grep them to spot anything they forgot to fill.

AEGIS_VERSION=__AEGIS_VERSION__
AEGIS_DOMAIN=__AEGIS_DOMAIN__

# === Core security =========================================================
# Without SSL/TLS terminated above us we MUST stay on localhost. External
# access goes through nginx (deploy/compose) and/or Cloudflare Tunnel.
UVICORN_HOST=127.0.0.1
UVICORN_PORT=__PANEL_PORT__
UVICORN_UDS=
UVICORN_SSL_CERTFILE=
UVICORN_SSL_KEYFILE=

# Compass §"管理面板加固" recommends ≤60 min; we take the conservative value.
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=45
JWT_SECRET_KEY=__JWT_SECRET__

# Compass §"非随意路径": dashboard and subscription paths must NOT be the
# defaults. install.sh randomizes both to 8 char URL-safe slugs.
DASHBOARD_PATH=__DASHBOARD_PATH__
XRAY_SUBSCRIPTION_PATH=__XRAY_SUBSCRIPTION_PATH__

# slowapi-backed rate limit (v0.1 already wires the dep).
ADMIN_LOGIN_RATE_LIMIT=5/minute

# === Database ==============================================================
# install.sh fills exactly one of the two URLs and leaves the other empty.
# Postgres is the default; SQLite is the S1 light variant.
SQLALCHEMY_DATABASE_URL=__DATABASE_URL__

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=__POSTGRES_PORT__
POSTGRES_DB=__POSTGRES_DB__
POSTGRES_USER=__POSTGRES_USER__
POSTGRES_PASSWORD=__POSTGRES_PASSWORD__

# === Redis (rate-limit / cache) ============================================
REDIS_HOST=127.0.0.1
REDIS_PORT=__REDIS_PORT__
REDIS_PASSWORD=__REDIS_PASSWORD__

# === Default admin =========================================================
# install.sh seeds this user on first boot only; subsequent runs leave it.
SUDO_USERNAME=__ADMIN_USERNAME__
SUDO_PASSWORD=__ADMIN_PASSWORD__

# === Xray policy (compass 五件套, item §Vision+短 connIdle) ================
# These are the operator-facing knobs; the actual Xray config consumes them
# via the panel's xray template. Do not raise connIdle above 180.
XRAY_POLICY_CONN_IDLE=120
XRAY_POLICY_HANDSHAKE=2

# === Non-standard ports (compass 五件套, item §非标准端口) =================
# Default panel port is 8443 (NOT 8080/80/443). Marznode gRPC stays on 62051
# but firewalls should restrict source to control-plane IP only.
PANEL_PORT=__PANEL_PORT__
MARZNODE_GRPC_PORT=__MARZNODE_GRPC_PORT__

# === Cloudflare Tunnel (compass 五件套, item §CF Tunnel) ===================
# install.sh --cf-tunnel yes flips CF_TUNNEL_ENABLED to true and chains into
# deploy/cloudflare/install-tunnel.sh (D.4, separate PR).
CF_TUNNEL_ENABLED=__CF_TUNNEL_ENABLED__
CF_ACCESS_REQUIRED_FOR_ADMIN=true
CF_TUNNEL_NAME=__CF_TUNNEL_NAME__
CF_TUNNEL_UUID=

# === Reality 2026 SNI defaults (compass 五件套, item §冷门 SNI) ============
# REALITY_SNI_REGION=auto walks the geo probe at first run; values below are
# the per-region fallbacks. Detailed selector logic lives in the S-R session
# (SPEC-sni-selector.md). DO NOT pick www.google.com / speedtest.net — they
# are on REALITY_SNI_BLOCKLIST and install.sh will refuse to start.
REALITY_SNI_REGION=auto
REALITY_SNI_DEFAULT_GLOBAL=www.microsoft.com
REALITY_SNI_DEFAULT_JP=www.lovelive-anime.jp
REALITY_SNI_DEFAULT_KR=static.naver.net
REALITY_SNI_DEFAULT_US=swdist.apple.com
REALITY_SNI_BLOCKLIST=www.google.com,speedtest.net

# uTLS fingerprint must be in {chrome,firefox,edge,safari,ios}. chrome_pq has
# a documented Reality bug; randomized is itself a fingerprint. Do not change
# without reading compass §"uTLS 选择".
REALITY_UTLS_FINGERPRINT=chrome
REALITY_FLOW=xtls-rprx-vision

# === Fallback channel (compass 五件套, item §备用通道) =====================
# v0.2 reserves the slots only; v0.3 (S-R session) wires automatic switchover.
FALLBACK_CHANNEL_ENABLED=false
FALLBACK_PORT_BACKUP=2053

# === Telegram bot (optional) ===============================================
TELEGRAM_API_TOKEN=
TELEGRAM_ADMIN_ID=

# === Subscription =========================================================
SUBSCRIPTION_URL_PREFIX=https://__AEGIS_DOMAIN__
