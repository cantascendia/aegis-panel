# =============================================================================
# Aegis Panel — production .env example
# This is the committed mirror of deploy/install/templates/env.tmpl.
#
# In a real install this file is rendered by deploy/install/install.sh and
# written to /opt/aegis/.env (mode 600). The __PLACEHOLDER__ tokens below are
# replaced at install time. If you copy this file by hand, EVERY line that
# contains `__RANDOMIZE_ON_INSTALL__` must be replaced with a real value
# before booting the panel. Run `grep __ /opt/aegis/.env` to spot misses.
#
# Compass 五件套 defaults are pre-applied (see SPEC-deploy.md §".env.example
# 强化项"): conservative JWT expiry, randomized paths, conn_idle=120s,
# non-standard panel port 8443, Reality SNI region defaults + blocklist,
# uTLS fingerprint = chrome, flow = xtls-rprx-vision.
# =============================================================================

AEGIS_VERSION=__RANDOMIZE_ON_INSTALL__
AEGIS_DOMAIN=__RANDOMIZE_ON_INSTALL__

# === Core security =========================================================
UVICORN_HOST=127.0.0.1
UVICORN_PORT=8443
UVICORN_UDS=
UVICORN_SSL_CERTFILE=
UVICORN_SSL_KEYFILE=

JWT_ACCESS_TOKEN_EXPIRE_MINUTES=45
JWT_SECRET_KEY=__RANDOMIZE_ON_INSTALL__

DASHBOARD_PATH=__RANDOMIZE_ON_INSTALL__
XRAY_SUBSCRIPTION_PATH=__RANDOMIZE_ON_INSTALL__

ADMIN_LOGIN_RATE_LIMIT=5/minute

# === Database ==============================================================
SQLALCHEMY_DATABASE_URL=__RANDOMIZE_ON_INSTALL__

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=aegis
POSTGRES_USER=aegis
POSTGRES_PASSWORD=__RANDOMIZE_ON_INSTALL__

# === Redis =================================================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=__RANDOMIZE_ON_INSTALL__

# === Default admin =========================================================
SUDO_USERNAME=__RANDOMIZE_ON_INSTALL__
SUDO_PASSWORD=__RANDOMIZE_ON_INSTALL__

# === Xray policy (compass 五件套, item §Vision+短 connIdle) ================
XRAY_POLICY_CONN_IDLE=120
XRAY_POLICY_HANDSHAKE=2

# === Non-standard ports (compass 五件套, item §非标准端口) =================
PANEL_PORT=8443
MARZNODE_GRPC_PORT=62051

# === Cloudflare Tunnel (compass 五件套, item §CF Tunnel) ===================
CF_TUNNEL_ENABLED=false
CF_ACCESS_REQUIRED_FOR_ADMIN=true
CF_TUNNEL_NAME=
CF_TUNNEL_UUID=

# === Reality 2026 SNI defaults (compass 五件套, item §冷门 SNI) ============
REALITY_SNI_REGION=auto
REALITY_SNI_DEFAULT_GLOBAL=www.microsoft.com
REALITY_SNI_DEFAULT_JP=www.lovelive-anime.jp
REALITY_SNI_DEFAULT_KR=static.naver.net
REALITY_SNI_DEFAULT_US=swdist.apple.com
REALITY_SNI_BLOCKLIST=www.google.com,speedtest.net

REALITY_UTLS_FINGERPRINT=chrome
REALITY_FLOW=xtls-rprx-vision

# === Fallback channel (compass 五件套, item §备用通道) =====================
FALLBACK_CHANNEL_ENABLED=false
FALLBACK_PORT_BACKUP=2053

# === Telegram bot (optional) ===============================================
TELEGRAM_API_TOKEN=
TELEGRAM_ADMIN_ID=

# === Subscription =========================================================
SUBSCRIPTION_URL_PREFIX=https://__RANDOMIZE_ON_INSTALL__
