# =============================================================================
# Aegis Panel — standalone marznode (data-plane) .env.example
#
# This file lives committed in the repo as a placeholder reference. The
# actual /opt/aegis-marznode/.env is rendered by install-node.sh (D.2)
# at install time. DO NOT commit a populated copy with real values.
#
# Refs: docs/ai-cto/SPEC-deploy.md §"目录结构" deploy/marznode/ + AC-D.2.*.
# =============================================================================

# Aegis release tag — pinned by install-node.sh --version. Default v0.2.0.
AEGIS_VERSION=v0.2.0

# Control-plane (panel) hostname or IP. Required at install time. Used by
# the bootstrap cert flow and printed in the success summary; the panel
# itself initiates the gRPC connection from this address.
CONTROL_PLANE_URL=panel.example.com

# Local gRPC listener port. Must match deploy/install/.env.example
# MARZNODE_GRPC_PORT (default 62051). Restrict source via ufw to the
# control-plane public IP.
GRPC_PORT=62051

# Slug-shaped node identifier; the panel "Add node" form expects an exact
# match. Allowed chars: A-Z a-z 0-9 . _ -
NODE_NAME=node-example-01

# Path to the marznode TLS cert PEM inside /opt/aegis-marznode. install-node.sh
# writes it here in step 5 (either fetched via --cert-mode bootstrap or
# copied from --cert-mode file). compose mounts /opt/aegis-marznode into
# /var/lib/marznode, so the in-container SSL_CERT_FILE points at the
# bind-mounted path.
CERT_PATH=/opt/aegis-marznode/marznode-cert.pem
